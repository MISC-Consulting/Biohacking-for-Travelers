{
  "version": 2,
  "buildCommand": "",
  "installCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "functions": {},
  "rewrites": [
    { "source": "/diagnostic", "destination": "/index.html" },
    { "source": "/waitlist", "destination": "/index.html" }
